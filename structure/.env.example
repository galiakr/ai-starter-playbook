# Copy to `.env.example` in the project root. Document every var here with a
# placeholder value — never a real one. This file IS committed; `.env` is not.

# --- App ---
VITE_APP_NAME=my-app
VITE_APP_ENV=development          # development | staging | production

# --- API ---
VITE_API_BASE_URL=http://localhost:3000/api

# --- Auth (if applicable) ---
VITE_AUTH_DOMAIN=
VITE_AUTH_CLIENT_ID=

# --- Third-party services (if applicable) ---
VITE_ANALYTICS_ID=
VITE_SENTRY_DSN=

# --- Backend-only secrets (if applicable — never prefix these with VITE_) ---
# DATABASE_URL=
# JWT_SECRET=
# STRIPE_SECRET_KEY=

# Rules (see AGENTS.md):
# - Every var used in the app must have an entry here, even if the value is blank.
# - Never commit a real value in this file.
# - Frontend-exposed vars must be prefixed per the build tool's convention (e.g. VITE_).
# - Backend secrets are never prefixed for exposure and are never read client-side.
